#!/usr/bin/env bash
set -euo pipefail

# Trigger fingerprint for run_onchange (re-runs when manifest changes).
# trigger-hash: {{ include "private_dot_ai/external-skills.json" | sha256sum }}

manifest="$HOME/.ai/external-skills.json"
state_dir="$HOME/.local/state/ai-shared"
log_file="$state_dir/external-skills.log"
stamp_file="$state_dir/external-skills.last-run"

if [[ ! -f "$manifest" ]]; then
    exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
    echo "Skipping external skill install: jq is required." >&2
    exit 0
fi

enabled_count="$(jq '[.skills[]? | select(.enabled != false)] | length' "$manifest")"
if [[ "$enabled_count" == "0" ]]; then
    exit 0
fi

if ! command -v npx >/dev/null 2>&1; then
    echo "Skipping external skill install: npx is required." >&2
    exit 0
fi

mkdir -p "$state_dir"

while IFS= read -r entry; do
    source_name="$(jq -r '.source // empty' <<<"$entry")"
    if [[ -z "$source_name" ]]; then
        continue
    fi

    mapfile -t agents < <(jq -r '.agents[]?' <<<"$entry")
    if ((${#agents[@]} == 0)); then
        agents=("claude-code" "codex")
    fi

    mapfile -t skill_names < <(jq -r '.skills[]?' <<<"$entry")

    cmd=(npx skills add "$source_name" -g --copy -y)
    for agent in "${agents[@]}"; do
        cmd+=( -a "$agent" )
    done
    for skill_name in "${skill_names[@]}"; do
        cmd+=( --skill "$skill_name" )
    done

    echo "Installing external skills from $source_name"
    "${cmd[@]}"

    printf '%s\t%s\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" "$source_name" >> "$log_file"
done < <(jq -c '.skills[]? | select(.enabled != false)' "$manifest")

date -u +"%Y-%m-%dT%H:%M:%SZ" > "$stamp_file"
