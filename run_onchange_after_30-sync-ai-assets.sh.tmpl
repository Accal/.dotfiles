#!/usr/bin/env bash
set -euo pipefail

# Trigger fingerprint for run_onchange (re-runs when private_dot_ai content changes).
# trigger-hash: {{ output "bash" "-lc" (print "cd " .chezmoi.sourceDir " && find private_dot_ai -type f -print0 | LC_ALL=C sort -z | xargs -0 cksum | cksum | awk '{print $1 \"::\" $2}'") }}

if ! command -v rsync >/dev/null 2>&1; then
    echo "Skipping shared AI sync: rsync is required." >&2
    exit 0
fi

AI_HOME="$HOME/.ai"

sync_tree() {
    local src="$1"
    local dest="$2"

    if [[ ! -d "$src" ]]; then
        return 0
    fi

    mkdir -p "$dest"
    rsync -a --delete "$src"/ "$dest"/
}

overlay_tree() {
    local src="$1"
    local dest="$2"

    if [[ ! -d "$src" ]]; then
        return 0
    fi

    mkdir -p "$dest"
    rsync -a "$src"/ "$dest"/
}

mkdir -p "$HOME/.claude" "$HOME/.codex"

sync_tree "$AI_HOME/skills" "$HOME/.claude/skills"
sync_tree "$AI_HOME/skills" "$HOME/.codex/skills"

sync_tree "$AI_HOME/prompts" "$HOME/.claude/prompts"
sync_tree "$AI_HOME/prompts" "$HOME/.codex/prompts"

sync_tree "$AI_HOME/mcp" "$HOME/.claude/mcp"
sync_tree "$AI_HOME/mcp" "$HOME/.codex/mcp"

overlay_tree "$AI_HOME/agents/claude" "$HOME/.claude"
overlay_tree "$AI_HOME/agents/codex" "$HOME/.codex"
